{
    "name": "executor-editor",
    "version": "2.0.8",
    "description": "🔨 Display and evaluate your JavaScript code",
    "homepage": "https://piecioshka.github.io/executor-editor/demo",
    "license": "MIT",
    "author": {
        "name": "Piotr Kowalski",
        "email": "piecioshka@gmail.com",
        "url": "https://piecioshka.pl/"
    },
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "clear": "rm -rf dist/",
        "clear:all": "rm -rf node_modules/ && npm run clear",
        "build": "run-p build:*",
        "build:js": "webpack",
        "build:css": "./tools/styles.sh",
        "build:types": "tsc -p tsconfig.build.json",
        "watch": "run-p watch:*",
        "watch:js": "webpack -w",
        "watch:css": "./tools/styles-watch.sh",
        "dev": "npm run build",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "e2e": "playwright test"
    },
    "devDependencies": {
        "@playwright/test": "^1.61.0",
        "@types/escape-html": "^1.0.4",
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "@typescript-eslint/parser": "^8.61.1",
        "debounce": "^1.2.1",
        "escape-html": "^1.0.3",
        "eslint": "^8.57.1",
        "eslint-config-piecioshka": "^2.3.7",
        "http-server": "^14.1.1",
        "npm-run-all": "^4.1.5",
        "sass": "^1.101.0",
        "selection-range": "^1.1.0",
        "super-event-emitter": "^5.0.3",
        "ts-loader": "^9.6.1",
        "typescript": "^5.9.3",
        "webpack": "^5.107.2",
        "webpack-cli": "^7.0.3"
    },
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com/piecioshka/executor-editor.git"
    },
    "files": [
        "dist",
        "src",
        "package.json",
        "README.md",
        "LICENSE"
    ],
    "keywords": [
        "executor",
        "highlight",
        "syntax",
        "evaluate",
        "javascript",
        "typescript",
        "code",
        "editor",
        "embed",
        "slides",
        "presentation"
    ],
    "main": "./dist/index.js",
    "types": "./dist/types/index.d.ts"
}
